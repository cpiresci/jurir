<?xml version="1.0" encoding="utf-8"?>
<!--
  [FIX] Allows cleartext (HTTP) traffic to localhost and 10.x.x.x only.
  Production traffic to jusaii-app-*.onrender.com still goes over HTTPS.
  Reference: android:networkSecurityConfig in AndroidManifest.xml
-->
<network-security-config>
    <!-- Allow cleartext only for local dev (emulator + USB debug) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
    <!-- Production: HTTPS only -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

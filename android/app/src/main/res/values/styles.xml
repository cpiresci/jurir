<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- [fix-stale-android-theme] Tema base era Light (identidade visual
         antiga) — site real é dark. statusBarColor/navigationBarColor
         direto no tema nativo porque não há @capacitor/status-bar
         instalado pra fazer isso via JS. minSdk=24, então
         windowLightStatusBar é seguro sem qualifier de versão. -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:navigationBarColor">@color/colorPrimaryDark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="AppTheme.NoActionBar" parent="AppTheme"/>
    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme"/>
</resources>

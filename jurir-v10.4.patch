+
+  const attempt = () => fetchWithTimeout(url, options);
+
+  let r;
+  try {
+    r = await attempt();
+  } catch (e) {
+    // Retry único em falhas de rede (típico no Capacitor durante cold start)
+    if (e.name === 'TypeError' || e.name === 'AbortError') {
+      await new Promise(res => setTimeout(res, 1200));
+      r = await attempt();

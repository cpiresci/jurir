<?xml version="1.0" encoding="UTF-8"?>
<!--
  [sitemap-hashrouter] O app usa HashRouter (jurir.com/#/rota) pra navegação
  interna — isso continua assim (migrar pra BrowserRouter é projeto maior,
  mais arriscado, o reset de senha depende do parsing de hash hoje).
  Posts do blog, porém, agora têm um caminho real e estático além do hash
  (https://jurir.com/blog/<slug>/, gerado por scripts/prerender-blog-og.js
  no build) — cada post ganha um HTML próprio com og:tags corretas e é isso
  que o sitemap referencia abaixo, não mais o fragmento #.
  Atualizar manualmente ao adicionar posts novos em src/lib/blogPosts.js.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://jurir.com/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://jurir.com/#/blog</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://jurir.com/blog/quanto-tempo-demora-processo-trabalhista/</loc>
    <changefreq>monthly</changefreq>
